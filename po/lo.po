msgid "Show menu only on Right Click"
msgstr "ສະແດງເມນູສະເພາະຕອນຄລິກຂວາ"

#: thunar/thunar-preferences-dialog.c:1064
msgid "Always show menu"
msgstr "ສະແດງເມນູສະເໝີ"

#: thunar/thunar-preferences-dialog.c:1073
msgid ""
"Disabled:\n"
"\t- Ignore file dragging.\n"
"Show menu only on Right Click:\n"
"\t- Left click + drag:\n"
"\t\tTo same drive: Move\n"
"\t\tTo different drive: Copy\n"
"\t- Right click + drag:\n"
"\t\tShow a menu to select an action.\n"
"Always show menu:\n"
"\t- Show a menu to select an action.\n"
"\n"
"Keyboard-shortcuts to select the action ahead of the drop:\n"
"\t- [Ctrl]: Copy\n"
"\t- [Shift]: Move\n"
"\t- [Ctrl]+[Shift]: Create a Link"
msgstr "ປິດໃຊ້ງານ:\n\t- ບໍ່ສົນໃຈການລາກໄຟລ໌.\nສະແດງເມນູສະເພາະຕອນຄລິກຂວາ:\n\t- ຄລິກຊ້າຍ + ລາກ:\n\t\tໃນໄດຣຟ໌ດຽວກັນ: ຍ້າຍ\n\t\tຄົນລະໄດຣຟ໌: ສຳເນົາ\n\t- ຄລິກຂວາ + ລາກ:\n\t\tສະແດງເມນູເພື່ອເລືອກການກະທຳ.\nສະແດງເມນູສະເໝີ:\n\t- ສະແດງເມນູເພື່ອເລືອກການກະທຳ.\n\nທາງລັດຄີບອດສຳລັບການເລືອກການກະທຳກ່ອນວາງ:\n\t- [Ctrl]: ສຳເນົາ\n\t- [Shift]: ຍ້າຍ\n\t- [Ctrl]+[Shift]: ສ້າງລິງກ໌"

#: thunar/thunar-preferences-dialog.c:1098
