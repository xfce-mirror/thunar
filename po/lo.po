#: ../thunar/thunar-action-manager.c:273
msgid "Open With Other _Application..."
msgstr "ເປີດດ້ວຍແອັບພລິເຄຊັນອື່ນ(_A)..."

#: ../thunar/thunar-action-manager.c:273
#: ../thunar/thunar-action-manager.c:3294
msgid "Choose another application with which to open the selected file"
msgstr "ເລືອກແອັບພລິເຄຊັນອື່ນເພື່ອເປີດໄຟລ໌ທີ່ເລືອກ"

#: ../thunar/thunar-action-manager.c:274
msgid "Set _Default Application..."
msgstr "ຕັ້ງຄ່າແອັບພລິເຄຊັນ_ເລີ່ມຕົ້ນ..."

#: ../thunar/thunar-action-manager.c:274
msgid ""
"Choose an application which should be used by default to open the selected "
"file"
msgstr "ເລືອກແອັບພລິເຄຊັນທີ່ຈະໃຊ້ເປັນມາດຕະຖານເພື່ອເປີດໄຟລ໌ທີ່ເລືອກ"

#. For backward compatibility the old accel paths are re-used. Currently not
#. possible to automatically migrate to new accel paths.
