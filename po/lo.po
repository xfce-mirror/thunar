#: ../thunar/thunar-action-manager.c:285 ../thunar/thunar-application.c:2627
#: ../plugins/thunar-tpa/thunar-tpa.c:175
msgid "_Empty Trash"
msgstr "ເທຖັງຂີ້ເຫຍື້ອ(_E)"

#: ../thunar/thunar-action-manager.c:285
msgid "Delete all files and folders in the Trash"
msgstr "ລຶບໄຟລ໌ ແລະ ໂຟນເດີທັງໝົດໃນຖັງຂີ້ເຫຍື້ອ"

#: ../thunar/thunar-action-manager.c:286
msgid "_Remove from Recent"
msgstr "ເອົາອອກຈາກລາຍການຫຼ້າສຸດ(_R)"

#: ../thunar/thunar-action-manager.c:286
msgid "Remove the selected files from Recent"
msgstr "ເອົາໄຟລ໌ທີ່ເລືອກອອກຈາກລາຍການຫຼ້າສຸດ"

#: ../thunar/thunar-action-manager.c:287
msgid "Create _Folder..."
msgstr "ສ້າງໂຟນເດີ...(_F)"

#: ../thunar/thunar-action-manager.c:287
msgid "Create an empty folder within the current folder"
msgstr "ສ້າງໂຟນເດີເປົ່າພາຍໃນໂຟນເດີປັດຈຸບັນ"

#: ../thunar/thunar-action-manager.c:288
msgid "Create _Document"
msgstr "ສ້າງເອກະສານ(_D)"

#: ../thunar/thunar-action-manager.c:288
msgid "Create a new document from a template"
msgstr "ສ້າງເອກະສານໃໝ່ຈາກແມ່ແບບ"

#: ../thunar/thunar-action-manager.c:290
msgid "_Restore"
msgstr "ກູ້ຄືນ(_R)"

#: ../thunar/thunar-action-manager.c:291
msgid "_Restore and Show"
msgstr "_ກູ້ຄືນ ແລະ ສະແດງ"

#: ../thunar/thunar-action-manager.c:291
msgid "_Restore and show the file(s)"
msgstr "_ກູ້ຄືນ ແລະ ສະແດງໄຟລ໌(s)"

#: ../thunar/thunar-action-manager.c:292
msgid "Mo_ve to Trash"
msgstr "ຖິ້ມລົງຖັງຂີ້ເຫຍື້ອ(_V)"

#: ../thunar/thunar-action-manager.c:293 ../thunar/thunar-application.c:2424
#: ../plugins/thunar-uca/thunar-uca-chooser.c:375
msgid "_Delete"
msgstr "ລຶບ(_D)"

#: ../thunar/thunar-action-manager.c:298
msgid "_Paste"
msgstr "ວາງ(_P)"

#: ../thunar/thunar-action-manager.c:298
msgid "Move or copy files previously selected by a Cut or Copy command"
msgstr "ຍ້າຍ ຫຼື ສຳເນົາໄຟລ໌ທີ່ຖືກເລືອກກ່ອນໜ້ານີ້ດ້ວຍຄຳສັ່ງຕັດ ຫຼື ສຳເນົາ"

#: ../thunar/thunar-action-manager.c:300
msgid "_Paste Into Folder"
msgstr "ວາງລົງໃນໂຟນເດີ(_P)"

#: ../thunar/thunar-action-manager.c:300
msgid ""
"Move or copy files previously selected by a Cut or Copy command into the "
"selected folder"
msgstr ""
"ຍ້າຍ ຫຼື ສຳເນົາໄຟລ໌ທີ່ຖືກເລືອກກ່ອນໜ້ານີ້ດ້ວຍຄຳສັ່ງຕັດ ຫຼື ສຳເນົາ "
"ລົງໃນໂຟນເດີທີ່ເລືອກ"

#: ../thunar/thunar-action-manager.c:301
msgid "_Copy"
msgstr "ສຳເນົາ(_C)"

#: ../thunar/thunar-action-manager.c:301
msgid "Prepare the selected files to be copied with a Paste command"
msgstr "ກຽມໄຟລ໌ທີ່ເລືອກເພື່ອສຳເນົາດ້ວຍຄຳສັ່ງວາງ"

#: ../thunar/thunar-action-manager.c:303
msgid "Cu_t"
msgstr "ຕັດ(_T)"

#: ../thunar/thunar-action-manager.c:303
msgid "Prepare the selected files to be moved with a Paste command"
msgstr "ກຽມໄຟລ໌ທີ່ເລືອກເພື່ອຍ້າຍດ້ວຍຄຳສັ່ງວາງ"

#: ../thunar/thunar-action-manager.c:306
msgid "_Mount"
msgstr "ຕິດຕັ້ງ(_M)"

#: ../thunar/thunar-action-manager.c:306
msgid "Mount the selected device"
msgstr "ຕິດຕັ້ງອຸປະກອນທີ່ເລືອກ"

#: ../thunar/thunar-action-manager.c:307
msgid "_Unmount"
msgstr "ຖອນການຕິດຕັ້ງ(_U)"

#: ../thunar/thunar-action-manager.c:307
msgid "Unmount the selected device"
msgstr "ຖອນການຕິດຕັ້ງອຸປະກອນທີ່ເລືອກ"

#: ../thunar/thunar-action-manager.c:308 ../thunar/thunar-device.c:538
msgid "_Eject"
msgstr "ດີດອອກ(_E)"

#: ../thunar/thunar-action-manager.c:308
msgid "Eject the selected device"
msgstr "ດີດອຸປະກອນທີ່ເລືອກອອກ"

#: ../thunar/thunar-action-manager.c:309
msgid "_Edit Launcher"
msgstr "ແກ້ໄຂຕົວເລີ່ມແອັບ(_E)"

#: ../thunar/thunar-action-manager.c:309
msgid "Edit the selected launcher"
msgstr "ແກ້ໄຂຕົວເປີດໂປຣແກຣມທີ່ເລືອກ"

