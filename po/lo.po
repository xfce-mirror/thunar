#. fix that
#: ../thunar/thunar-action-manager.c:278
msgid "_Send To"
msgstr "ສົ່ງໄປທີ່(_S)"

#: ../thunar/thunar-action-manager.c:279
msgid "_Add Bookmark"
msgstr "ເພີ່ມບຸກມາກ(_A)"

#: ../thunar/thunar-action-manager.c:279
msgid ""
"Create bookmarks for all selected folders. If nothing is selected, the "
"current folder is bookmarked."
msgstr ""
"ສ້າງບຸກມາກສຳລັບໂຟນເດີທີ່ເລືອກທັງໝົດ. ຖ້າບໍ່ມີການເລືອກ, "
"ຈະບຸກມາກໂຟນເດີປັດຈຸບັນ."

#: ../thunar/thunar-action-manager.c:280
msgid "Send to _Desktop"
msgstr "ສົ່ງໄປທີ່ເດັສທັອບ(_D)"

#: ../thunar/thunar-action-manager.c:281
msgid "_Properties..."
msgstr "ຄຸນສົມບັດ...(_P)"

#: ../thunar/thunar-action-manager.c:281
msgid "View the properties of the selected file"
msgstr "ເບິ່ງຄຸນສົມບັດຂອງໄຟລ໌ທີ່ເລືອກ"

#: ../thunar/thunar-action-manager.c:282
#: ../thunar/thunar-action-manager.c:1613
msgid "Ma_ke Link"
msgid_plural "Ma_ke Links"
msgstr[0] "ສ້າງລິງກ໌(_K)"

#: ../thunar/thunar-action-manager.c:283
msgid "Du_plicate"
msgstr "ເຮັດສຳເນົາ(_p)"

#: ../thunar/thunar-action-manager.c:284
msgid "_Rename..."
msgstr "ປ່ຽນຊື່...(_R)"

